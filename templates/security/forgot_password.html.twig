{% extends 'base.html.twig' %}
{% block title %}Mot de passe oublié — Grooty{% endblock %}

{% block body %}
<div class="main" style="max-width:460px;padding-top:3rem;">
    <div class="card">
        <h1 style="font-family:'Fraunces',serif;font-size:1.5rem;font-weight:300;margin-bottom:.4rem;">
            Mot de passe oublié
        </h1>
        <p style="color:var(--muted);font-size:.88rem;margin-bottom:1.5rem;">
            Entrez votre email — vous recevrez un lien pour créer un nouveau mot de passe.
        </p>

        <form method="post">
            <div class="form-group">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" required
                       placeholder="votre@email.com" autofocus>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">
                Envoyer le lien
            </button>
        </form>

        <div style="text-align:center;margin-top:1.2rem;">
            <a href="{{ path('app_login') }}" style="font-size:.85rem;color:var(--muted);">
                ← Retour à la connexion
            </a>
        </div>
    </div>
</div>
{% endblock %}
