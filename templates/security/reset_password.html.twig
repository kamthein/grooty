{% extends 'base.html.twig' %}
{% block title %}Nouveau mot de passe — Grooty{% endblock %}

{% block body %}
<div class="main" style="max-width:460px;padding-top:3rem;">
    <div class="card">
        <h1 style="font-family:'Fraunces',serif;font-size:1.5rem;font-weight:300;margin-bottom:.4rem;">
            Nouveau mot de passe
        </h1>
        <p style="color:var(--muted);font-size:.88rem;margin-bottom:1.5rem;">
            Choisissez un nouveau mot de passe (6 caractères minimum).
        </p>

        <form method="post">
            <div class="form-group">
                <label class="form-label">Nouveau mot de passe</label>
                <input type="password" name="password" class="form-control" required
                       minlength="6" placeholder="••••••••" autofocus>
            </div>
            <div class="form-group">
                <label class="form-label">Confirmer</label>
                <input type="password" name="confirm" class="form-control" required
                       minlength="6" placeholder="••••••••">
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">
                Enregistrer le mot de passe
            </button>
        </form>
    </div>
</div>
{% endblock %}
