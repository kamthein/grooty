{% extends 'base.html.twig' %}
{% block title %}Déjà répondu — Grooty{% endblock %}
{% block body %}
<div class="main" style="max-width:500px;padding-top:3rem;text-align:center;">
    <div style="font-size:3rem;margin-bottom:1rem;">{{ status == 'approved' ? '✅' : '❌' }}</div>
    <h1 style="font-family:'Fraunces',serif;font-size:1.5rem;font-weight:300;margin-bottom:.8rem;">Déjà répondu</h1>
    <p style="color:var(--muted);font-size:.9rem;">Vous avez déjà {{ status == 'approved' ? 'validé' : 'refusé' }} cette modification.</p>
</div>
{% endblock %}
