{% extends 'base.html.twig' %}
{% block title %}Historique — {{ child.firstName }} — Grooty{% endblock %}

{% block stylesheets %}
<style>
.history-item {
    display: flex; gap: 1rem; padding: .8rem 0;
    border-bottom: 1px solid var(--warm);
    align-items: flex-start;
}
.history-item:last-child { border-bottom: none; }
.history-icon {
    width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: .9rem;
}
.icon-created  { background: rgba(61,90,71,.1); }
.icon-updated  { background: rgba(196,113,74,.1); }
.icon-deleted  { background: rgba(220,53,69,.1); }
.icon-approved { background: rgba(61,90,71,.1); }
.icon-rejected { background: rgba(220,53,69,.1); }
.icon-proposed { background: rgba(255,193,7,.15); }
.icon-notified { background: rgba(100,149,237,.1); }
.history-label { font-size: .88rem; font-weight: 500; color: var(--ink); line-height: 1.4; }
.history-meta  { font-size: .75rem; color: var(--muted); margin-top: 2px; }
</style>
{% endblock %}

{% block body %}
<div class="main" style="max-width:700px;">
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;">
        <a href="{{ path('app_child_show', {'id': child.id}) }}" class="btn btn-ghost btn-sm">← Retour</a>
        <h1 style="font-family:'Fraunces',serif;font-size:1.5rem;font-weight:300;">
            Historique de <em style="font-style:italic;color:var(--terracotta)">{{ child.firstName }}</em>
        </h1>
    </div>

    {% if history is empty %}
    <div class="card" style="text-align:center;color:var(--muted);padding:3rem;">
        <p>Aucun historique pour le moment.</p>
    </div>
    {% else %}
    <div class="card">
        {% for h in history %}
        {% set icons = {
            'created':  {icon: '✨', cls: 'icon-created'},
            'updated':  {icon: '✏️', cls: 'icon-updated'},
            'deleted':  {icon: '🗑️', cls: 'icon-deleted'},
            'approved': {icon: '✅', cls: 'icon-approved'},
            'rejected': {icon: '❌', cls: 'icon-rejected'},
            'proposed': {icon: '⏳', cls: 'icon-proposed'},
            'notified': {icon: '📧', cls: 'icon-notified'},
        } %}
        {% set ico = icons[h.action] ?? {icon: '📌', cls: ''} %}
        <div class="history-item">
            <div class="history-icon {{ ico.cls }}">{{ ico.icon }}</div>
            <div style="flex:1;">
                <div class="history-label">{{ h.label }}</div>
                <div class="history-meta">
                    {{ h.createdAt|date('d/m/Y à H:i') }}
                    {% if h.event %}— {{ h.event.title }}{% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>
{% endblock %}
